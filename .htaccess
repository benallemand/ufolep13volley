AddDefaultCharset UTF-8

# Bloque l'accès à tous les fichiers/dossiers cachés (.env, .git, .htaccess…),
# sauf .well-known. Évite notamment l'exposition du .env.
RedirectMatch 404 /\.(?!well-known)

# Bundles Vite des pages HTML pures : on conserve les URLs publiques
# (/pages/home.html, /pages/my_page.html, /admin/matches.html) mais le
# contenu servi est le HTML transformé par Vite dans dist/.
RewriteEngine On
RewriteRule ^live\.html$ /dist/live.html [L]
RewriteRule ^match\.html$ /dist/match.html [L]
RewriteRule ^survey\.html$ /dist/survey.html [L]
RewriteRule ^team_sheets\.html$ /dist/team_sheets.html [L]
RewriteRule ^pages/(home|my_page)\.html$ /dist/pages/$1.html [L]
RewriteRule ^admin/matches\.html$ /dist/admin/matches.html [L]
